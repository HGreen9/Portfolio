---
import ProjectLayout from '../../layouts/projectLayout.astro';
import Sidebar from '../../components/sidebar.astro';
import DustParticle from '../../components/dustParticle.astro';
---

<ProjectLayout
  title="Kobold Adventures"
  icon="🗺️"
  year="2026"
  medium="Digital Illustration"
  tags={["Digital"]}
  image="/images/Ro Kobold.png"
  backLink="/illustration"
>

  <Fragment slot="breadcrumb">
    <a href="/">Home</a> / <a href="/illustration">Illustration</a> / <span>Kobold Adventures</span>
  </Fragment>

  <Sidebar slot="sidebar" />

  <section class="project-description">
    <h2>About the Project</h2>
    <p>
      A Digital Illustration of a character created for an unreleased webtoon series, 2026
        </p>
  </section>

  <section class="project-tools">
    <h2>Tools Used</h2>
    <ul>
      <li>ibisPaint X</li>
    </ul>
  </section>
</ProjectLayout>

<DustParticle />