---
import ProjectLayout from '../../layouts/projectLayout.astro';
import Sidebar from '../../components/sidebar.astro';
import DustParticle from '../../components/dustParticle.astro';
---

<ProjectLayout
  title="Nyxara Smoke and Glass"
  icon="🍷"
  year="2026"
  medium="Digital Illustration"
  tags={["Digital"]}
  image="/images/Nyx glass.png"
  backLink="/illustration"
>

  <Fragment slot="breadcrumb">
    <a href="/">Home</a> / <a href="/illustration">Illustration</a> / <span>Nyxara Smoke and Glass</span>
