  <Sidebar slot="sidebar" />

  <section class="project-description">
    <h2>About the Project</h2>
    <p>
      A Digital Illustration for a D&D playlist, 2026.
        </p>
  </section>

  <section class="project-tools">
    <h2>Tools Used</h2>
    <ul>
      <li>ibisPaint X</li>
    </ul>
  </section>
</ProjectLayout>

<DustParticle />