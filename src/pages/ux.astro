---
import BaseLayout from '../layouts/baseLayout.astro';
import Sidebar from '../components/sidebar.astro';
import UXBanner from '../components/ux/gallerybanner.astro';
import UXCards from '../components/ux/gallerycards.astro';
import Backtotop from '../components/backtotop.astro';
import DustParticle from '../components/dustParticle.astro';
---

<BaseLayout title="UX Case Studies">
	<Sidebar slot="sidebar" />

	<link rel="stylesheet" href="/styles/gallery.css" />
	<script src="/scripts/highlight.js" defer></script>

	<h1>🧭 UX Case Studies</h1>

	<div class="filters">
		<button data-filter="all">Show All</button>
		<button data-filter="Research">Research</button>
		<button data-filter="Wireframe">Wireframe</button>
		<button data-filter="Prototype">Prototype</button>
		<button data-filter="Usability">Usability</button>
	</div>

	<section class="gallery-banner">
		<UXBanner />
	</section>

	<div class="gallery">
		<UXCards />
	</div>
  
	<Backtotop />

	<script src="/scripts/filter.js" defer></script>
</BaseLayout>

<DustParticle />


