---
const { title, tags = [], year, medium, image, backLink = "/", icon = "🖼️" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script>
      // Minimal synchronous theme setter for project pages
      (function(){
        try {
          var KEY = 'portfolio-dark-mode';
          var cookie = document.cookie || '';
          var cookiePref = cookie.indexOf(KEY + '=true') !== -1 ? 'true' : (cookie.indexOf(KEY + '=false') !== -1 ? 'false' : null);
          var ls = null;
          try { ls = localStorage.getItem(KEY); } catch(e) {}
          var pref = (cookiePref !== null) ? cookiePref : ls;
          // critical styles moved to global.css, no inline injection here
          if (pref === 'true') {
            document.documentElement.classList.add('dark-mode');
            document.body.classList.add('dark-mode');
          } else if (pref === null) {
            try {
              if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.classList.add('dark-mode');
                document.body.classList.add('dark-mode');
              }
            } catch (e) {}
          }
        } catch (e) {}
      })();
    </script>
    <style id="critical-dark-inline">html.dark-mode, body.dark-mode { background-color: #1a1a1a; color: #dea95fc8; }
      html.dark-mode .art-piece, body.dark-mode .art-piece { background-color: #2d2d2d; border-color: #3f3f3f; color: #b8a895; }
      html.dark-mode .art-piece p, body.dark-mode .art-piece p { color: #b8a895; }
      html.dark-mode .art-piece strong, body.dark-mode .art-piece strong { color: #d4c9b8; }
      html.dark-mode .tag, body.dark-mode .tag { background-color: #4a4a4a; color: #e8e8e8; }
      html.dark-mode .project-link a, body.dark-mode .project-link a { color: #b8a895; background-color: #3f3f3f; }
      html.dark-mode .frame, body.dark-mode .frame { background: #2d2d2d; border-color: #4a4a4a; }
      html.dark-mode .project h1, body.dark-mode .project h1 { color: #d4c9b8; }
      html.dark-mode .project-info p, body.dark-mode .project-info p { color: #b8a895; }
      html.dark-mode .project-description h2, body.dark-mode .project-description h2,
      html.dark-mode .project-tools h2, body.dark-mode .project-tools h2 { color: #b8a895; }
      html.dark-mode .back-link, body.dark-mode .back-link { color: #b8a895; background-color: #3f3f3f; }
      html.dark-mode .breadcrumb, body.dark-mode .breadcrumb { color: #8a7a65; }
      html.dark-mode .breadcrumb a, body.dark-mode .breadcrumb a { color: #8a7a65; }
      html.dark-mode .art-piece.highlighted, body.dark-mode .art-piece.highlighted { outline: 2px solid #a89878; box-shadow: 0 0 12px rgba(168, 152, 120, 0.5); animation: fadeHighlightDark 2.5s ease forwards; }
      @keyframes fadeHighlightDark {
        0% { box-shadow: 0 0 12px rgba(168, 152, 120, 0.5); background-color: #3d3d3d; }
        50% { box-shadow: 0 0 6px rgba(168, 152, 120, 0.3); background-color: #363636; }
        100% { box-shadow: 0 0 0 rgba(0, 0, 0, 0); background-color: #2d2d2d; outline: none; }
      }
    </style>
    <link rel="stylesheet" href="/styles/global.css" />
    <link rel="stylesheet" href="/styles/project.css" />
    <link rel="stylesheet" href="/styles/dark-mode.css" />
    <link rel="stylesheet" href="/styles/media-query.css" />
  </head>
  <body>
    <a href="#main-content" id="skip-link" class="skip-link">Skip to main content</a>
    <button id="dark-mode-toggle" class="dark-mode-toggle" aria-label="Toggle dark mode" aria-describedby="dark-mode-desc">
      <span class="icon" aria-hidden="true">🌙</span>
      <span id="dark-mode-desc" class="sr-only">Toggle site between dark and light mode</span>
      <span class="tooltip" role="tooltip">Dark mode</span>
    </button>
    <div class="container">
      <nav class="sidebar" aria-label="Primary navigation">
        <slot name="sidebar" />
      </nav>

  <main id="main-content" class="content">
    <nav class="breadcrumb">
      <slot name="breadcrumb" />
    </nav>

    <article class="project">
      <h1>{icon} {title}</h1>

      {image && (
        <img src={image} alt={title + " artwork"} class="project-hero" draggable="false"/>
      )}

      <section class="project-info">
        <p><strong>Medium:</strong> {medium}</p>
        <p><strong>Year:</strong> {year}</p>
        {tags.length > 0 && (
          <p><strong>Tags:</strong> {tags.join(", ")}</p>
        )}
      </section>

      <slot />

      <a href={backLink} class="back-link">← Back to Gallery</a>
    </article>
  </main>
    </div>

  <script>
    const observers = document.querySelectorAll('.animate-slide');
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    });
    observers.forEach(el => observer.observe(el));
  </script>

  <script src="/scripts/dark-mode.js" is:inline></script>
  <script src="/scripts/universal.js" is:inline></script>
  </body>
</html>
