---
const { title = "My Portfolio" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script>
      // Minimal synchronous theme setter: runs before CSS loads.
      (function(){
        try {
          var KEY = 'portfolio-dark-mode';
          var cookie = document.cookie || '';
          var cookiePref = cookie.indexOf(KEY + '=true') !== -1 ? 'true' : (cookie.indexOf(KEY + '=false') !== -1 ? 'false' : null);
          var ls = null;
          try { ls = localStorage.getItem(KEY); } catch(e) {}
          var pref = (cookiePref !== null) ? cookiePref : ls;
          // quick-critical CSS to avoid flash for key elements
          // critical styles have been moved to global.css so no inline injection needed
          if (pref === 'true') {
            document.documentElement.classList.add('dark-mode');
            document.body.classList.add('dark-mode');
          } else if (pref === null) {
            // respect OS preference when no explicit pref
            try {
              if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.classList.add('dark-mode');
                document.body.classList.add('dark-mode');
              }
            } catch (e) {}
          }
        } catch (e) {}
      })();
    </script>
    <style id="critical-dark-inline">
      html.dark-mode, body.dark-mode { background-color: #1a1a1a; color: #dea95fc8; }
      html.dark-mode .art-piece, body.dark-mode .art-piece { background-color: #2d2d2d; border-color: #3f3f3f; color: #b8a895; }
      html.dark-mode .art-piece p, body.dark-mode .art-piece p { color: #b8a895; }
      html.dark-mode .art-piece strong, body.dark-mode .art-piece strong { color: #d4c9b8; }
      html.dark-mode .tag, body.dark-mode .tag { background-color: #4a4a4a; color: #e8e8e8; }
      html.dark-mode .project-link a, body.dark-mode .project-link a { color: #b8a895; background-color: #3f3f3f; }
      html.dark-mode .frame, body.dark-mode .frame { background: #2d2d2d; border-color: #4a4a4a; }
      html.dark-mode .art-piece.highlighted, body.dark-mode .art-piece.highlighted { outline: 2px solid #a89878; box-shadow: 0 0 12px rgba(168, 152, 120, 0.5); animation: fadeHighlightDark 2.5s ease forwards; }
      @keyframes fadeHighlightDark {
        0% { box-shadow: 0 0 12px rgba(168, 152, 120, 0.5); background-color: #3d3d3d; }
        50% { box-shadow: 0 0 6px rgba(168, 152, 120, 0.3); background-color: #363636; }
        100% { box-shadow: 0 0 0 rgba(0, 0, 0, 0); background-color: #2d2d2d; outline: none; }
      }
    </style>
    
    <!-- Favicons -->
    <link rel="icon" href="/favicons/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicons/favicon-32x32.png" type="image/png" />
    <link rel="icon" href="/favicons/favicon-16x16.png" type="image/png" />
    <link rel="apple-touch-icon" href="/favicons/apple-touch-icon.png" />
    
    <link rel="stylesheet" href="/styles/global.css" />
    <link rel="stylesheet" href="/styles/dark-mode.css" />
    <link rel="stylesheet" href="/styles/media-query.css" />

  </head>
  <body>
    <a href="#main-content" id="skip-link" class="skip-link">Skip to main content</a>
    <button id="dark-mode-toggle" class="dark-mode-toggle" aria-label="Toggle dark mode" aria-describedby="dark-mode-desc">
      <span class="icon" aria-hidden="true">🌙</span>
      <span id="dark-mode-desc" class="sr-only">Toggle site between dark and light mode</span>
      <span class="tooltip" role="tooltip">Dark mode</span>
    </button>
    <div class="container">
      <nav class="sidebar" aria-label="Primary navigation">
        <slot name="sidebar" />
      </nav>
      <main id="main-content" class="content">
        <slot />
      </main>
    </div>
    <script src="/scripts/dark-mode.js" is:inline></script>
    <script src="/scripts/universal.js" is:inline></script>
  </body>
</html>
